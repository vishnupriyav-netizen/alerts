-- collect 

-- 2. zeros filled gap query 


-- For a 2 hours interval if Q1 is > 0 in past 15-20 days and for the same interval we get 0 collects for a provider and collection_ccy combination then alert


with top as (
select provider, charge_currency,
countDistinct(payin_id) as collect_traffic 
from payin where toDate(payin_created_at) >= toDate(now()) - interval 30 day and substr(payin_id, 1,3) = 'col'
group by 1,2
having collect_traffic > 10
order by collect_traffic desc  
),

date_range as (
  select toDate(now()) - interval number day as date
  from numbers(20)
),

hour_range as (
  select concat(toString(number * 2), '-', toString(number * 2 + 2)) as hour
  from numbers(12)
),

all_combinations as (
  select t.provider, t.charge_currency, d.date, h.hour
  from top t
  cross join date_range d
  cross join hour_range h
),


historics as (
select a.provider as provider, a.charge_currency as charge_currency , 
toDate(b.payin_created_at) as date, 
concat(toString(intDiv(toHour(b.payin_created_at), 2) * 2), '-', toString(intDiv(toHour(b.payin_created_at), 2) * 2 + 2)) as hour,
countDistinct(payin_id) as collect_traffic 
from top a 
left join payin b 
on a.provider = b.provider and a.charge_currency = b.charge_currency
where toDate(b.payin_created_at) >= toDate(now()) - interval 20 day  and 
substr(b.payin_id, 1,3) = 'col'
group by 1,2,3,4
)
,

complete_data as (
  select 
    ac.provider as provider,
    ac.charge_currency  as charge_currency,
    ac.date as date,
    ac.hour as hour,
    coalesce(h.collect_traffic, 0) as collect_traffic
  from all_combinations ac
  left join historics h 
  on ac.provider = h.provider 
  and ac.charge_currency = h.charge_currency 
  and ac.date = h.date 
  and ac.hour = h.hour
),

quartile_stats as (
  select 
    provider,
    charge_currency as charge_currency,
    hour,
    quantile(0.25)(collect_traffic) as q1_collect_traffic,
    quantile(0.50)(collect_traffic) as median_collect_traffic,
    quantile(0.75)(collect_traffic) as q3_collect_traffic,
    avg(collect_traffic) as avg_collect_traffic,
    count() as total_data_points
  from complete_data
where date < toDate(now()) 
  group by provider, charge_currency, hour
),

now_traffic as (
select provider, charge_currency, 
date, hour, collect_traffic 
from complete_data a

where date = toDate(now() - interval 2 hour)
and hour = concat(toString(intDiv(toHour(now() - interval 2 hour), 2) * 2), '-', 
                  toString(intDiv(toHour(now() - interval 2 hour), 2) * 2 + 2))

-- where  date = toDate(now()) 
-- and hour =  concat(toString(intDiv(toHour(now()), 2) * 2), '-', toString(intDiv(toHour(now()), 2) * 2 + 2))

)


select 
  n.provider,
  n.charge_currency,
  n.date as current_date,
  n.hour as current_hour_interval,
  n.collect_traffic as current_traffic,
  q.q1_collect_traffic as q1_historic_collect_traffic,
  case when q.q1_collect_traffic > 0 and current_traffic = 0 then 'alert' end as status
  
from now_traffic n
left join quartile_stats q 
  on n.provider = q.provider 
  and n.charge_currency = q.charge_currency 
  and n.hour = q.hour




